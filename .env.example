# Required in production. Empty value leaves admin routes OPEN (dev only).
# Generate with: openssl rand -hex 24
WIW_ADMIN_TOKEN=

# Server (defaults shown)
API_PORT=3011
UNIFIED=1
# PORT=2568           # only used when UNIFIED=0
# CLIENT_DIST=../client/dist

# Client overrides (optional — leave blank for same-origin auto-detection)
# VITE_API_URL=
# VITE_WS_URL=
